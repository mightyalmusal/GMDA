# Microsoft Entra (Azure AD) - same as sourcecode
VITE_AAD_TENANT_ID=your-tenant-id
VITE_AAD_CLIENT_ID=your-client-id
VITE_ALLOWED_EMAILS=
AAD_TENANT_ID=your-tenant-id
AAD_CLIENT_ID=your-client-id
AUTH_POLICY=tenant
ALLOWED_EMAILS=

# Role-based access (comma-separated emails)
# Owner: sees everything including Settings, Data, and Publish button
# Editor: sees dashboards + Budget/Target + Mapping only
# If VITE_OWNER_EMAILS is empty, everyone is treated as owner (local dev fallback)
VITE_OWNER_EMAILS=owner@yourcompany.com
VITE_EDITOR_EMAILS=editor1@yourcompany.com,editor2@yourcompany.com

# Meta API credentials (local dev only — for cloud, set these in Cloudflare dashboard as secrets)
META_ACCESS_TOKEN=your_meta_token_here

# Cloudflare R2 credentials (local dev only — cloud uses R2 binding instead)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=marketing-hub-data
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# ── Cloudflare Pages deployment env vars (set in Cloudflare dashboard) ────────
# META_ACCESS_TOKEN=your_meta_token_here      ← set as Secret
# META_APP_ID=your_meta_app_id
# META_APP_SECRET=your_meta_app_secret        ← set as Secret
# BUSINESS_ACCOUNT_IDS=123456,789012          ← comma-separated
# R2 credentials are NOT needed for cloud — use R2 binding named "BUCKET" instead
